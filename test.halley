data Nat {
    Zero { },
    Succ { previous: Nat },
}

data Option {
    None {},
    Some { value: Int },
}

data List {
    Nil {},
    Cons { head: Bool, tail: List },
}

data Tree {
    Leaf {},
    Node { left: &Tree, right: &Tree }
}

fn f(a: Nat, b: Option, c: List, d: Tree) -> Bool {
    true
}
